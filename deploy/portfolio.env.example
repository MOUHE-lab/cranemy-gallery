# Copy this file to /etc/portfolio-gallery/portfolio.env on the server.
# Do not commit the real production password.

PORT=8080

MYSQL_URL=jdbc:mysql://127.0.0.1:3306/portfolio_gallery?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=portfolio_user
MYSQL_PASSWORD=change-this-password

UPLOAD_DIR=/var/lib/portfolio-gallery/uploads
UPLOAD_MAX_BYTES=8388608
UPLOAD_MAX_IMAGE_BYTES=8388608
UPLOAD_MAX_VIDEO_BYTES=209715200
UPLOAD_MAX_FILE_SIZE=200MB
UPLOAD_MAX_REQUEST_SIZE=210MB

SESSION_TIMEOUT=30m
